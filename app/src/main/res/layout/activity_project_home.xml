<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_bg"
    android:fillViewport="true"
    android:scrollbars="none">

    <LinearLayout
        android:id="@+id/project_home_root_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="0dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="44dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/project_home_title"
                    android:textColor="@color/editor_text_primary"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif"
                    android:text="@string/project_home_subtitle"
                    android:textColor="@color/editor_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_project_home_count"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:background="@drawable/bg_editor_chip_idle"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:minWidth="78dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textColor="@color/editor_text_primary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/button_project_home_create_top"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_project_panel_action"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:minWidth="72dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/project_home_create"
                android:textColor="@color/editor_text_primary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_project_home_current"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_project_panel_card"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/project_panel_label"
                android:textColor="@color/editor_text_secondary"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/text_project_home_current_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:textColor="@color/editor_text_primary"
                android:textSize="24sp" />

            <TextView
                android:id="@+id/text_project_home_current_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/editor_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_project_home_current_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/editor_text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/button_project_home_open"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_project_panel_action"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/project_home_continue"
                    android:textColor="@color/editor_text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/button_project_home_apply_wallpaper"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_project_panel_action"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="@string/project_home_apply"
                    android:textColor="@color/editor_text_primary"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/text_project_home_recent_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="@string/project_home_other_projects"
                android:textColor="@color/editor_text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_project_home_recent_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="@string/project_home_recent_hint"
                android:textColor="@color/editor_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_project_home_recent_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/layout_project_home_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_project_recent_item_current"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/text_project_home_empty_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/editor_text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/text_project_home_empty_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:textColor="@color/editor_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
