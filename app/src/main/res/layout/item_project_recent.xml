<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_project_recent_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:background="@drawable/bg_project_recent_item"
    android:gravity="center_vertical"
    android:minHeight="54dp"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingTop="8dp"
    android:paddingEnd="12dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_project_recent_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/editor_text_primary"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/text_project_recent_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:textColor="@color/editor_text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_project_recent_badge"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_editor_chip_idle"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:minWidth="44dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="@string/project_recent_current"
        android:textColor="@color/editor_text_primary"
        android:textSize="10sp"
        android:visibility="gone" />
</LinearLayout>
