<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="312dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_project_panel_card"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <TextView
        android:id="@+id/text_project_confirm_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/editor_text_primary"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/text_project_confirm_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:textColor="@color/editor_text_secondary"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/button_project_confirm_cancel"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:background="@drawable/bg_project_panel_action"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/project_dialog_cancel"
            android:textColor="@color/editor_text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/button_project_confirm_delete"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_project_panel_action_danger"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/project_menu_delete"
            android:textColor="@color/editor_fix_text"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
