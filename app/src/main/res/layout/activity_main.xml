<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/editor_bg">

    <!-- 编辑器主容器：顶部工具栏、中央工作区和底部图层区都挂在这里。 -->
    <LinearLayout
        android:id="@+id/editor_root_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/editor_bg"
        android:orientation="vertical"
        android:paddingTop="0dp">

        <!-- 顶部菜单栏：保留状态栏留白，但不直接展示系统状态内容。 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/editor_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageView
                android:id="@+id/button_editor_menu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:contentDescription="@string/editor_menu"
                android:padding="0dp"
                android:scaleType="center"
                android:src="@drawable/ic_header_menu_vector" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:id="@+id/text_header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/editor_header_default_title"
                    android:textColor="@color/editor_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/text_header_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/editor_header_default_subtitle"
                    android:textColor="@color/editor_text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/button_editor_redo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/editor_save"
                android:padding="0dp"
                android:scaleType="center"
                android:src="@drawable/ic_header_save_vector" />

            <ImageButton
                android:id="@+id/button_editor_undo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/editor_history"
                android:padding="0dp"
                android:scaleType="center"
                android:src="@drawable/ic_header_history_vector" />

            <ImageButton
                android:id="@+id/button_add_layer"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/editor_add"
                android:padding="0dp"
                android:scaleType="center"
                android:src="@drawable/ic_header_plus_vector" />
        </LinearLayout>

        <!-- 中央工作区：左侧项目条、中间预览框、右侧工具塔。 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="402dp"
            android:background="@drawable/bg_editor_workspace"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/image_project_strip_background"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_pencil_project_strip_full" />

                <LinearLayout
                    android:id="@+id/layout_context_strip_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="22dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/image_context_strip_icon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_pencil_editor_type_rect" />

                    <TextView
                        android:id="@+id/text_context_strip_line_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/editor_context_strip_line_1"
                        android:textColor="@color/editor_text_on_dark"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/text_context_strip_line_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/editor_context_strip_line_2"
                        android:textColor="@color/editor_text_on_dark"
                        android:textSize="10sp" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="382dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="28dp"
                    android:layout_marginEnd="32dp"
                    android:background="@drawable/bg_editor_preview_frame"
                    android:padding="1dp">

                    <com.example.klwpdemo.EditorRuntimePreviewView
                        android:id="@+id/runtime_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#1C1C1C" />
                </FrameLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/editor_tools_rail"
                android:layout_width="60dp"
                android:layout_height="match_parent">

                <!-- 工具塔底图来自 Pencil 导出的稿源素材，代码只负责对齐交互层。 -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="fitXY"
                    android:src="@drawable/bg_pencil_tools_rail_full" />

                <View
                    android:id="@+id/view_tools_active_indicator"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="13dp"
                    android:background="@drawable/bg_editor_tool_indicator" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:alpha="0"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingTop="13dp"
                    android:paddingBottom="13dp">

                    <ImageButton
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_expand"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_fit" />

                    <ImageButton
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_focus"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_focus" />

                    <ImageButton
                        android:id="@+id/button_tool_lock"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_lock"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_lock" />

                    <ImageButton
                        android:id="@+id/button_tool_layers"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_layers"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_layers" />

                    <ImageButton
                        android:id="@+id/button_tool_adjust"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_adjust"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_pause" />

                    <ImageButton
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_widgets"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_widgets" />

                    <ImageButton
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_charts"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_chart" />

                    <ImageButton
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_editor_icon_button_tool"
                        android:contentDescription="@string/editor_tool_settings"
                        android:padding="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_pencil_editor_settings" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:background="@drawable/bg_editor_issue_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/text_issue_primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:text="@string/editor_issue_missing_request"
                android:textColor="@color/editor_text_on_dark"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/text_issue_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/editor_fix_now"
                android:textColor="@color/editor_fix_text"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 图层统计文本只作为逻辑载体，不直接显示在界面上。 -->
        <TextView
            android:id="@+id/text_layer_count"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- 底部区域：项目页签和当前容器的内容列表。 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="316dp"
            android:background="@color/editor_list_surface">

            <LinearLayout
                android:id="@+id/editor_layer_panel"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tab_project"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_editor_tab_active"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="@string/editor_tab_project"
                        android:textColor="@color/editor_text_primary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tab_layer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_editor_tab_idle"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="@string/editor_tab_layer"
                        android:textColor="@color/editor_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tab_position"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_editor_tab_idle"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="@string/editor_tab_position"
                        android:textColor="@color/editor_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tab_global"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_editor_tab_idle"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="@string/editor_tab_global"
                        android:textColor="@color/editor_text_secondary"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/tab_animation"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_editor_tab_idle"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="@string/editor_tab_animation"
                        android:textColor="@color/editor_text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <ScrollView
                    android:id="@+id/layer_list_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="270dp"
                    android:background="@drawable/bg_editor_layer_list_surface"
                    android:clipToPadding="false"
                    android:fillViewport="true"
                    android:paddingStart="0dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="0dp"
                    android:paddingBottom="0dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/layer_list_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- 右侧属性浮层：只有进入编辑态时才覆盖显示。 -->
    <ScrollView
        android:id="@+id/editor_property_panel"
        android:layout_width="188dp"
        android:layout_height="344dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="144dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_editor_property_panel"
        android:fillViewport="true"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_selected_layer_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:text="@string/editor_property_none"
                    android:textColor="@color/editor_text_primary"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/button_property_close"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/bg_editor_chip_idle"
                    android:contentDescription="@string/editor_property_close"
                    android:padding="6dp"
                    android:src="@drawable/ic_editor_close"
                    android:tint="@color/editor_text_primary" />
            </LinearLayout>

            <Button
                android:id="@+id/button_property_delete"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_editor_secondary_button"
                android:fontFamily="sans-serif-medium"
                android:text="@string/editor_delete_layer"
                android:textAllCaps="false"
                android:textColor="@color/editor_text_primary"
                android:textSize="12sp" />

            <!-- 仅当选中形状图层时才展示填充色配置。 -->
            <LinearLayout
                android:id="@+id/property_fill_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/editor_property_fill"
                    android:textColor="@color/editor_text_secondary"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/button_fill_color_rose"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:background="@drawable/bg_editor_fill_swatch"
                        android:contentDescription="@string/editor_fill_color_rose" />

                    <ImageButton
                        android:id="@+id/button_fill_color_blue"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_editor_fill_swatch"
                        android:contentDescription="@string/editor_fill_color_blue" />

                    <ImageButton
                        android:id="@+id/button_fill_color_mint"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_editor_fill_swatch"
                        android:contentDescription="@string/editor_fill_color_mint" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/editor_property_position_x"
                android:textColor="@color/editor_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_position_x_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="0"
                android:textColor="@color/editor_text_primary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_position_x"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="400"
                android:progress="200"
                android:progressTint="@color/editor_accent"
                android:thumbTint="@color/editor_accent" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/editor_property_position_y"
                android:textColor="@color/editor_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_position_y_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="0"
                android:textColor="@color/editor_text_primary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_position_y"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="400"
                android:progress="200"
                android:progressTint="@color/editor_accent"
                android:thumbTint="@color/editor_accent" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/editor_property_opacity"
                android:textColor="@color/editor_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_opacity_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="100%"
                android:textColor="@color/editor_text_primary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_opacity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100"
                android:progressTint="@color/editor_accent"
                android:thumbTint="@color/editor_accent" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/editor_property_scale"
                android:textColor="@color/editor_text_secondary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_scale_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="100%"
                android:textColor="@color/editor_text_primary"
                android:textSize="12sp" />

            <SeekBar
                android:id="@+id/seek_scale"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="400"
                android:min="20"
                android:progress="100"
                android:progressTint="@color/editor_accent"
                android:thumbTint="@color/editor_accent" />
        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/project_panel_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/project_panel_card_host"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="64dp"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true">

            <include layout="@layout/popup_project_panel" />
        </FrameLayout>
    </FrameLayout>
</FrameLayout>
