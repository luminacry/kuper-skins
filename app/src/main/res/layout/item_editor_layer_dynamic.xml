<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layer_row_root"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingEnd="9dp">

    <!-- 左侧拖拽柄只负责还原视觉密度，当前版本不改动真实排序逻辑。 -->
    <ImageView
        android:id="@+id/image_layer_grip"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_pencil_editor_grip" />

    <ImageView
        android:id="@+id/image_layer_type"
        android:layout_width="17dp"
        android:layout_height="17dp"
        android:layout_marginStart="2dp"
        android:contentDescription="@null"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_pencil_editor_type_group" />

    <!-- 中间文本区会根据图层深度动态增加缩进。 -->
    <LinearLayout
        android:id="@+id/layer_text_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/text_layer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/editor_text_primary"
            android:textSize="10.5sp" />

        <TextView
            android:id="@+id/text_layer_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/editor_text_secondary"
            android:textSize="7.5sp" />
    </LinearLayout>

    <!-- 右侧显隐图标只更新 UI，不改变底部列表的数据结构。 -->
    <ImageView
        android:id="@+id/image_layer_visible"
        android:layout_width="17dp"
        android:layout_height="17dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_pencil_editor_checkbox"
        android:contentDescription="@null" />
</LinearLayout>
