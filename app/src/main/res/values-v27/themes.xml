    <style name="Theme.KlwpDemo" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/editor_bg</item>
        <item name="android:navigationBarColor">@color/editor_bg</item>
        <item name="android:windowBackground">@color/editor_bg</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
