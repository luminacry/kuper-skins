{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "assembleDebug (wrapper)",
      "type": "shell",
      "command": "${workspaceFolder}\\gradlew.bat",
      "args": [
        "assembleDebug",
        "--offline"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gradle"
      ]
    }
  ]
}
